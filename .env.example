# Copie este arquivo para .env e preencha os valores
# No Railway, configure estas variáveis em Settings > Variables

# Token da API Autentique (obrigatório)
AUTENTIQUE_TOKEN=seu_token_aqui

# Senha para proteger o sistema (opcional, mas recomendado)
APP_PASSWORD=sua_senha_aqui

# Dados da empresa
EMPRESA=JS Construtora
RESP_SST=Nome do Responsável SST
CNPJ=00.000.000/0000-00

# Banco de dados (Railway preenche automaticamente)
DATABASE_URL=

# Porta (Railway preenche automaticamente)
PORT=8000
